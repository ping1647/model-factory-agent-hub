{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "StockAudit",
  "type": "object",
  "required": [
    "ticker",
    "model_id",
    "decision",
    "risk_score",
    "position_class",
    "evidence_quality",
    "benchmark_etf",
    "verified_facts",
    "bull_case",
    "bear_case",
    "kill_switches",
    "missing_data",
    "blocked_by",
    "next_action"
  ],
  "properties": {
    "ticker": {
      "type": "string"
    },
    "company": {
      "type": "string"
    },
    "model_id": {
      "type": "string"
    },
    "decision": {
      "enum": [
        "Buy",
        "Starter",
        "Wait",
        "Risk-Blocked",
        "Avoid"
      ]
    },
    "risk_score": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10
    },
    "position_class": {
      "type": "string"
    },
    "evidence_quality": {
      "enum": [
        "High",
        "Medium-High",
        "Medium",
        "Low",
        "Missing Data"
      ]
    },
    "benchmark_etf": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "verified_facts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "model_estimates": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "weak_signals": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "growth_drivers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "profitability_quality": {
      "type": "string"
    },
    "balance_sheet": {
      "type": "string"
    },
    "moat": {
      "type": "string"
    },
    "valuation": {
      "type": "string"
    },
    "bull_case": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "bear_case": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "kill_switches": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "missing_data": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "blocked_by": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_action": {
      "type": "string"
    },
    "human_approval_required": {
      "type": "boolean"
    }
  }
}