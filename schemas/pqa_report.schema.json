{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PqaReport",
  "type": "object",
  "required": [
    "ticker",
    "passed",
    "checks",
    "failures",
    "warnings",
    "severity",
    "next_action"
  ],
  "properties": {
    "ticker": {"type": "string"},
    "passed": {"type": "boolean"},
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["check_name", "passed", "severity", "message"],
        "properties": {
          "check_name": {"type": "string"},
          "passed": {"type": "boolean"},
          "severity": {"type": "string", "enum": ["Pass", "Warning", "Fail"]},
          "message": {"type": "string"}
        }
      }
    },
    "failures": {"type": "array", "items": {"type": "string"}},
    "warnings": {"type": "array", "items": {"type": "string"}},
    "severity": {"type": "string", "enum": ["Pass", "Warning", "Fail"]},
    "next_action": {"type": "string"}
  }
}
