{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DataAudit",
  "type": "object",
  "required": [
    "ticker",
    "model_id",
    "current_price",
    "price_as_of",
    "price_freshness_status",
    "stale_price",
    "benchmark_etf",
    "benchmark_status",
    "buy_zone_low",
    "buy_zone_high",
    "buy_zone_status",
    "gap_to_buy_zone_pct",
    "eps_guidance_midpoint",
    "forward_pe",
    "valuation_status",
    "decision_blockers",
    "data_quality",
    "next_action"
  ],
  "properties": {
    "ticker": {"type": "string"},
    "model_id": {"type": "string"},
    "current_price": {"type": ["number", "null"]},
    "price_as_of": {"type": ["string", "null"]},
    "price_freshness_status": {"type": "string"},
    "stale_price": {"type": "boolean"},
    "benchmark_etf": {"type": "array", "items": {"type": "string"}},
    "benchmark_status": {"type": "string"},
    "buy_zone_low": {"type": ["number", "null"]},
    "buy_zone_high": {"type": ["number", "null"]},
    "buy_zone_status": {"type": "string"},
    "gap_to_buy_zone_pct": {"type": ["number", "null"]},
    "eps_guidance_midpoint": {"type": ["number", "null"]},
    "forward_pe": {"type": ["number", "null"]},
    "valuation_status": {"type": "string"},
    "decision_blockers": {"type": "array", "items": {"type": "string"}},
    "data_quality": {"type": "string", "enum": ["Usable", "Blocked"]},
    "next_action": {"type": "string"}
  }
}
