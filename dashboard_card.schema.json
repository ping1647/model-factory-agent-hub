{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DashboardCard",
  "type": "object",
  "required": [
    "ticker",
    "decision",
    "risk_score",
    "status",
    "position_class",
    "blocked_by",
    "next_action"
  ],
  "properties": {
    "ticker": {
      "type": "string"
    },
    "company": {
      "type": "string"
    },
    "model_id": {
      "type": "string"
    },
    "decision": {
      "type": "string"
    },
    "risk_score": {
      "type": "integer"
    },
    "risk_color": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "position_class": {
      "type": "string"
    },
    "benchmark_etf": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "blocked_by": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "missing_data": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_action": {
      "type": "string"
    },
    "freshness": {
      "type": "string"
    }
  }
}